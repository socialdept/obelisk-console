# Obelisk Console — production env. Copy to `.env` on the VPS and fill in.
#   cp .env.production.example .env

# The Obelisk archive. On the shared network you can use the internal address
# (faster, no public round-trip):
#   OBELISK_API_URL=http://app:6060
# or the public URL:
OBELISK_API_URL=https://obelisk.socialde.pt

# A bearer token minted on the archive (bun run scripts/create-token.ts console).
OBELISK_API_TOKEN=

# atproto DIDs allowed to log in (comma-separated). Everyone else is refused.
OPERATOR_DIDS=did:plc:xxxxxxxxxxxxxxxxxxxxxxxx

# iron-session cookie secret — must be >= 32 chars. Generate: openssl rand -hex 32
SESSION_SECRET=

# The console's public domain (used only by the archive Caddy vhost, see README).
# The app derives its OAuth client_id/redirect from the request origin at runtime,
# so no NEXT_PUBLIC_OAUTH_* vars are needed.
CONSOLE_DOMAIN=console.obelisk.socialde.pt
